OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro
OPENAI_THINKING=enabled
OPENAI_REASONING_EFFORT=high
OPENAI_TIMEOUT=180
OPENAI_MAX_RETRIES=0
LOG_LEVEL=INFO
LOG_FORMAT=console
GITHUB_TOKEN=
GITHUB_MAX_FILE_BYTES=512000
GITHUB_TIMEOUT=30
GITHUB_MAX_RETRIES=3
MAX_CANDIDATE_FILES=12
MAX_PLANNING_PATHS=80
MAX_FILE_CHARS=16000
MAX_TOTAL_CONTEXT_CHARS=80000
MAX_OUTPUT_TOKENS=8000
MAX_AGENT_ITERATIONS=15
MAX_INVESTIGATION_LEDGER_CHARS=12000
MAX_CHAT_TOKENS=2000
INDEPENDENT_REVIEW=true
# REVIEW_MODEL=
REVIEW_MAX_TOKENS=8000
MAX_REVIEW_CONTEXT_CHARS=32000
MAX_REPORT_RETRIES=3
LANGUAGE=zh
# API_KEY=
# WRITE_MODE=false
SESSION_DB_PATH=data/sessions.db
SESSION_STALE_AFTER_SECONDS=1800
SESSION_RETENTION_DAYS=30
MAX_PR_FILES=20
MAX_PR_TOTAL_BYTES=1000000
MAX_SESSION_IMPORT_BYTES=5242880
# Circuit breaker: fast-fail LLM calls after N consecutive failures
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY=30
# Batch analysis: max concurrent investigations and queue capacity
BATCH_MAX_CONCURRENT=2
BATCH_MAX_QUEUE_SIZE=100
